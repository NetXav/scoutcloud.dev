# ScoutCloud environment variables
# Copy to .env and update after each chapter
# NEVER commit .env to git - it is in .gitignore

DATABASE_URL=placeholder      # Chapter 7: postgresql://scoutadmin:PASS@HOST:5432/scoutcloud
DYNAMODB_TABLE=placeholder    # Chapter 8: scoutcloud-live-scores
SECRET_ARN=                   # Chapter 14: arn:aws:secretsmanager:...
COGNITO_USER_POOL_ID=         # Chapter 17: us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=            # Chapter 17: 26-char client ID
AWS_REGION=us-east-1          # all chapters
